ANTHROPIC_API_KEY=use-your-key
OPENAI_API_KEY=use-your-key

# Optional — Telegram alerts. If both are unset the alert layer is a no-op,
# so local runs stay silent. To enable: create a bot via @BotFather, then
# get your chat_id from https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LangChain works best with Anthropic/Claude but the script can be extended to support also other LLM providers
