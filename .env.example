ANTHROPIC_API_KEY=use-your-key
OPENAI_API_KEY=use-your-key

# Optional — Telegram alerts. If both are unset the alert layer is a no-op,
# so local runs stay silent. Easiest setup: python scripts/telegram_setup.py
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional — Slack alerts. Paste an Incoming Webhook URL to mirror every alert
# into a Slack channel. Telegram and Slack can both be on at once.
SLACK_WEBHOOK_URL=

# Optional — watchlist as raw CSV (overrides watchlist.csv). Mainly for CI /
# containers; locally just use the watchlist.csv file.
# WATCHLIST_CSV=

# Optional — cost controls. If COST_BUDGET_USD is set and the month-to-date
# spend (see --cost) is at or above it, runs no-op until the next month.
# SCOUT_MAIN_MODEL and SCOUT_URGENT_MODEL swap the LLM per path; defaults are
# Sonnet for the daily run and Haiku for the cheap urgent path.
# COST_BUDGET_USD=5
# SCOUT_MAIN_MODEL=claude-sonnet-4-6
# SCOUT_URGENT_MODEL=claude-haiku-4-5-20251001

# LangChain works best with Anthropic/Claude but the script can be extended to support also other LLM providers
